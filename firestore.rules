// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields: id, full_name, email, role, package_id, status, ...
//
// Collection: packages
// Fields: id, name, price, upload_limit, ...
//
// Collection: athletes
// Fields: id, profile_id, full_name, specialty, ...
//
// Collection: videos
// Fields: id, title, video_url, visibility_status, allowed_packages, ...
//
// Collection: user_video_uploads
// Fields: id, user_id, video_url, status, ...
//
// Collection: programs
// Fields: id, title, video_ids, status, ...
//
// Collection: program_assignments
// Fields: id, user_id, program_id, status, ...
//
// Collection: retreats
// Fields: id, title, visibility_status, access_type, allowed_packages, ...
//
// Collection: communities
// Fields: id, name, status, ...
//
// Collection: community_posts
// Fields: id, community_id, content, created_by, ...
//
// Collection: brands
// Fields: id, name, slug, ...
//
// Collection: products
// Fields: id, brand_id, name, price, status, ...
//
// Collection: orders
// Fields: id, user_id, total_amount, payment_status, fulfillment_status, ...
//
// Collection: activity_logs
// Fields: id, actor_id, action, metadata, ...
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "fashionmeetzfitness86@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'super_admin')
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "fashionmeetzfitness86@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'admin' || getUserData().role == 'super_admin'))
      );
    }

    function isAthlete() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'athlete';
    }

    function isNotBanned() {
      return !isAuthenticated() || 
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             getUserData().get('status', 'active') != 'banned';
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================

    function isValidUser(data) {
      return data.full_name is string && data.full_name.size() > 0 && data.full_name.size() < 100 &&
             data.email is string && data.role in ['user', 'admin', 'super_admin', 'athlete'];
    }

    function isValidVideo(data) {
      return data.title is string && data.video_url is string && 
             data.visibility_status in ['published', 'draft', 'hidden', 'archived'];
    }

    function isValidProduct(data) {
      return data.name is string && data.price is number && data.price >= 0;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || isSuperAdmin());
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status) || 
        isAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /athletes/{athleteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if (resource.data.visibility_status == 'published') || (
        isNotBanned() && (
          isAdmin() ||
          (isAuthenticated() && 
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           resource.data.allowed_packages.hasAny([getUserData().get('package_id', '')]))
        )
      );
      allow write: if isAdmin();
    }

    match /video_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_video_uploads/{uploadId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.user_id);
      allow update: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow delete: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
    }

    match /programs/{programId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /program_assignments/{assignmentId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow write: if isAdmin();
    }

    match /retreats/{retreatId} {
      allow read: if (resource.data.visibility_status == 'published') || (
        isNotBanned() && (
          isAdmin() ||
          (isAuthenticated() && (
            (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.allowed_packages.hasAny([getUserData().get('package_id', '')])) ||
            resource.data.allowed_users.hasAny([request.auth.uid])
          ))
        )
      );
      allow write: if isAdmin();
    }

    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /community_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (isOwner(resource.data.created_by) || isAdmin());
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /product_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carts/{cartId} {
      allow read, write: if isAuthenticated() && isOwner(resource.data.user_id);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.user_id);
      allow update: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && isOwner(resource.data.user_id);
      allow write: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
    }
  }
}
